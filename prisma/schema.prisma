generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String          @id @default(cuid())
  email         String?         @unique
  phone         String?         @unique
  passwordHash  String
  name          String?
  plan          String          @default("free")
  dailyUsage          Int             @default(0)
  lastUsageDate       String?
  lastNicknameChange  DateTime?
  failedLoginAttempts Int             @default(0)
  lockedUntil    DateTime?
  tokenVersion   Int             @default(0)
  englishLevel       String?         // "middle"|"high"|"cet4"|"cet6"|"ielts"
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  writings          Writing[]
  corrections       Correction[]
  optimizations     Optimization[]
  savedWords        SavedWord[]
  savedGrammars     SavedGrammar[]
  sentRequests      Friendship[]    @relation("SentRequests")
  receivedRequests  Friendship[]    @relation("ReceivedRequests")
  sentMessages       Message[]         @relation("SentMessages")
  receivedMessages   Message[]         @relation("ReceivedMessages")
  createdWordbooks   Wordbook[]        @relation("CreatedWordbooks")
  wordbookMemberships WordbookMember[]
  addedWords         WordbookWord[]
  challengeSubmissions ChallengeSubmission[]
  dailyWordSessions  DailyWordSession[]
}

model SmsCode {
  id        String    @id @default(cuid())
  phone     String
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone])
  @@index([createdAt])
}

model SmsRateLimit {
  id            String   @id @default(cuid())
  phone         String
  count         Int      @default(1)
  windowStartAt DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([phone, windowStartAt])
}

model Writing {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceText   String
  resultText   String
  style        String   @default("daily")
  examType     String   @default("general")
  grammarNotes String?
  vocabNotes   String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model Correction {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  essayText        String
  examType         String   @default("general")
  totalScore       Float
  maxScore         Float
  scores           String   // JSON: ScoreBreakdown
  sentenceCorrections String // JSON: SentenceCorrection[]
  grammarIssues    String   // JSON: GrammarNote[]
  vocabSuggestions String   // JSON: VocabNote[]
  improvementSuggestions String? // JSON: ImprovementSuggestion[]
  overallComment   String
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
}

model SavedWord {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word         String
  chinese      String
  phoneticUK   String?  // 英式音标 IPA
  phoneticUS   String?  // 美式音标 IPA
  collocations String?  // JSON
  synonyms     String?  // JSON
  level        String?
  usage        String?
  examples     String?  // JSON
  commonErrors String?  // JSON
  examFocus    String?
  source       String   @default("translate")
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([userId, word])
}

model LoginAttempt {
  id             String   @id @default(cuid())
  email          String   @unique
  count          Int      @default(1)
  firstAttemptAt DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([firstAttemptAt])
}

model FriendRateLimit {
  id             String   @id @default(cuid())
  userId         String   @unique
  count          Int      @default(1)
  windowStartAt  DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([windowStartAt])
}

model SavedGrammar {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  point          String
  level          String?
  function       String?
  structure      String?
  explanation    String?
  examples       String?  // JSON
  commonMistakes String?  // JSON
  examTip        String?
  source         String   @default("translate")
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([userId, point])
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  requester   User     @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User     @relation("ReceivedRequests", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // "pending" | "accepted" | "blocked"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content     String   // 1~2000 字符，API 层校验
  contentType String?  // "writing" | "correction" | "savedWord" | "savedGrammar" — 分享内容的类型
  contentId   String?  // 原始记录 ID（分享内容时使用）
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([receiverId, read])
  @@index([senderId, createdAt])
  @@index([senderId, receiverId, createdAt])
}

model Wordbook {
  id        String            @id @default(cuid())
  name      String
  creatorId String
  creator   User              @relation("CreatedWordbooks", fields: [creatorId], references: [id], onDelete: Cascade)
  members   WordbookMember[]
  words     WordbookWord[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([creatorId])
  @@index([updatedAt])
}

model WordbookMember {
  id         String   @id @default(cuid())
  wordbookId String
  wordbook   Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String   @default("editor") // "owner" | "editor"
  joinedAt   DateTime @default(now())

  @@unique([wordbookId, userId])
  @@index([userId])
}

model Optimization {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalText    String
  optimizedText   String
  style           String   @default("daily")
  examType        String   @default("general")
  intensity       String   @default("medium")
  mode            String   @default("full")
  improvements    String   // JSON: ImprovementItem[]
  grammarNotes    String?  // JSON: GrammarNote[]
  vocabNotes      String?  // JSON: VocabNote[]
  highlights      String?
  transitionAnalysis String? // JSON: TransitionAnalysis (fragment mode)
  contextBefore   String?  // 片段模式上文
  contextAfter    String?  // 片段模式下文
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
}

model WordbookWord {
  id         String   @id @default(cuid())
  wordbookId String
  wordbook   Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)
  word       String
  chinese    String
  phoneticUK String?  // 英式音标 IPA
  phoneticUS String?  // 美式音标 IPA
  level      String?
  usage      String?
  addedById  String
  addedBy    User     @relation(fields: [addedById], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([wordbookId])
  @@index([wordbookId, createdAt])
}

model WeekendChallenge {
  id          String   @id @default(cuid())
  date        String   // "2026-06-27" — 周六或周日的日期
  difficulty  String   // "easy" | "hard"
  examType    String   // "cet4" | "ielts"
  topic       String   // 话题分类，如 "科技影响"、"社会热点"
  prompt      String   // 完整写作题目
  wordLimit   Int      // easy:150, hard:250
  timeLimit   Int      // easy:30, hard:40（分钟）
  status      String   @default("pending_review") // "pending_review" | "approved" | "rejected"
  source      String   @default("ai") // "ai" | "real_exam"

  submissions ChallengeSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, difficulty])  // 每天每个难度只有一道题
  @@index([date])
  @@index([status])
}

model ChallengeSubmission {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  content     String   // 用户提交的作文
  score       Float?   // 总分
  maxScore    Float?   // 满分
  scores      String?  // JSON: 各维度分数
  feedback    String?  // JSON: 完整 CorrectionResult（复用 correct.ts 的输出结构）
  wordCount   Int?
  timeSpent   Int?     // 实际用时（秒）
  createdAt   DateTime @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge WeekendChallenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])  // 每人每道题只能提交一次
  @@index([userId, createdAt])
  @@index([challengeId])
}

model DailyWordSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             String   // "YYYY-MM-DD"
  topic            String
  examType         String   // "cet4" | "cet6" | "high" | "ielts" ...
  difficulty       String   // "easy" | "medium" | "hard"
  words            String   // JSON: WordItem[]
  status           String   @default("generated") // "generated" | "practicing" | "scenario_ready" | "scenario" | "dictation" | "completed"
  currentWordIndex Int      @default(0)
  scenarioMessages String?  // JSON: ScenarioTurn[]
  dictationState   String?  // JSON: DictationState
  usageConsumed    Boolean  @default(false)
  topicChangeCount Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  practices WordPractice[]

  @@unique([userId, date])
  @@index([userId, createdAt])
}

model WordPractice {
  id            String   @id @default(cuid())
  sessionId     String
  session       DailyWordSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  word          String
  wordIndex     Int
  userSentence  String?
  aiScore       Int?     // 1-5
  aiComment     String?
  naturalness   String?  // "natural" | "okay" | "unnatural"
  grammarOk     Boolean?
  fullResponse  String?  // JSON: 完整 AI 评价原始数据
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sessionId, wordIndex])
}
