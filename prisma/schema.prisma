generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String          @id @default(cuid())
  email         String?         @unique
  phone         String?         @unique
  passwordHash  String
  name          String?
  plan          String          @default("free")
  dailyUsage    Int             @default(0)
  lastUsageDate String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  writings          Writing[]
  corrections       Correction[]
  optimizations     Optimization[]
  savedWords        SavedWord[]
  savedGrammars     SavedGrammar[]
  sentRequests      Friendship[]    @relation("SentRequests")
  receivedRequests  Friendship[]    @relation("ReceivedRequests")
  sentShares         SharedContent[]   @relation("SentShares")
  receivedShares     SharedContent[]   @relation("ReceivedShares")
  createdWordbooks   Wordbook[]        @relation("CreatedWordbooks")
  wordbookMemberships WordbookMember[]
  addedWords         WordbookWord[]
}

model SmsCode {
  id        String    @id @default(cuid())
  phone     String
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone])
  @@index([createdAt])
}

model SmsRateLimit {
  id            String   @id @default(cuid())
  phone         String
  count         Int      @default(1)
  windowStartAt DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([phone, windowStartAt])
}

model Writing {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceText   String
  resultText   String
  style        String   @default("daily")
  examType     String   @default("general")
  grammarNotes String?
  vocabNotes   String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model Correction {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  essayText        String
  examType         String   @default("general")
  totalScore       Float
  maxScore         Float
  scores           String   // JSON: ScoreBreakdown
  sentenceCorrections String // JSON: SentenceCorrection[]
  grammarIssues    String   // JSON: GrammarNote[]
  vocabSuggestions String   // JSON: VocabNote[]
  improvementSuggestions String? // JSON: ImprovementSuggestion[]
  overallComment   String
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
}

model SavedWord {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word         String
  chinese      String
  collocations String?  // JSON
  synonyms     String?  // JSON
  level        String?
  usage        String?
  examples     String?  // JSON
  commonErrors String?  // JSON
  examFocus    String?
  source       String   @default("translate")
  createdAt    DateTime @default(now())

  @@index([userId])
}

model LoginAttempt {
  id             String   @id @default(cuid())
  email          String
  count          Int      @default(1)
  firstAttemptAt DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([email])
  @@index([firstAttemptAt])
}

model SavedGrammar {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  point          String
  level          String?
  function       String?
  structure      String?
  explanation    String?
  examples       String?  // JSON
  commonMistakes String?  // JSON
  examTip        String?
  source         String   @default("translate")
  createdAt      DateTime @default(now())

  @@index([userId])
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  requester   User     @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User     @relation("ReceivedRequests", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // "pending" | "accepted" | "blocked"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@index([status])
}

model SharedContent {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentShares", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceivedShares", fields: [receiverId], references: [id], onDelete: Cascade)
  contentType String   // "writing" | "correction" | "savedWord" | "savedGrammar"
  contentId   String   // 原始记录 ID
  message     String?  // 发送者留言
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([receiverId, read])
  @@index([senderId, createdAt])
}

model Wordbook {
  id        String            @id @default(cuid())
  name      String
  creatorId String
  creator   User              @relation("CreatedWordbooks", fields: [creatorId], references: [id], onDelete: Cascade)
  members   WordbookMember[]
  words     WordbookWord[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model WordbookMember {
  id         String   @id @default(cuid())
  wordbookId String
  wordbook   Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String   @default("editor") // "owner" | "editor"
  joinedAt   DateTime @default(now())

  @@unique([wordbookId, userId])
}

model Optimization {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalText    String
  optimizedText   String
  style           String   @default("daily")
  examType        String   @default("general")
  intensity       String   @default("medium")
  mode            String   @default("full")
  improvements    String   // JSON: ImprovementItem[]
  grammarNotes    String?  // JSON: GrammarNote[]
  vocabNotes      String?  // JSON: VocabNote[]
  highlights      String?
  transitionAnalysis String? // JSON: TransitionAnalysis (fragment mode)
  contextBefore   String?  // 片段模式上文
  contextAfter    String?  // 片段模式下文
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
}

model WordbookWord {
  id         String   @id @default(cuid())
  wordbookId String
  wordbook   Wordbook @relation(fields: [wordbookId], references: [id], onDelete: Cascade)
  word       String
  chinese    String
  level      String?
  usage      String?
  addedById  String
  addedBy    User     @relation(fields: [addedById], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([wordbookId])
}
